{
  "name": "appium-safari-driver",
  "version": "5.0.3",
  "description": "Appium driver for Safari browser",
  "keywords": [
    "appium",
    "safari",
    "safaridriver"
  ],
  "author": "Appium Contributors",
  "license": "Apache-2.0",
  "homepage": "https://appium.github.io/appium-safari-driver",
  "repository": {
    "type": "git",
    "url": "https://github.com/appium/appium-safari-driver.git"
  },
  "bugs": {
    "url": "https://github.com/appium/appium-safari-driver/issues"
  },
  "type": "module",
  "main": "./build/lib/index.js",
  "types": "./build/lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./build/lib/index.d.ts",
      "import": "./build/lib/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {},
  "directories": {
    "lib": "lib"
  },
  "files": [
    "lib",
    "build/lib",
    "LICENSE",
    "CHANGELOG.md",
    "npm-shrinkwrap.json"
  ],
  "appium": {
    "driverName": "safari",
    "automationName": "Safari",
    "platformNames": [
      "Mac",
      "iOS"
    ],
    "mainClass": "SafariDriver"
  },
  "prettier": {
    "bracketSpacing": false,
    "printWidth": 100,
    "singleQuote": true
  },
  "scripts": {
    "build": "tsc -b",
    "clean": "npm run build -- --clean",
    "rebuild": "npm run clean; npm run build",
    "dev": "npm run build -- --watch",
    "lint": "eslint .",
    "lint:fix": "npm run lint -- --fix",
    "format": "prettier -w ./lib ./test",
    "format:check": "prettier --check ./lib ./test",
    "build:docs": "appium-docs build",
    "dev:docs": "appium-docs build --serve",
    "publish:docs": "appium-docs build --deploy --push -b docs-site -m 'docs: build docs for appium-safari-driver@%s' --alias latest --use-prefixed-major-deploy-version",
    "install-docs-deps": "appium-docs init --no-mkdocs",
    "prepare": "npm run build",
    "pretest": "npm run build",
    "test": "node --test --test-timeout=60000 \"build/test/unit/**/*.test.js\"",
    "e2e-test": "npm run build && node --test --test-timeout=300000 \"build/test/functional/**/*.test.js\"",
    "e2e-test:desktop": "npm run build && node --test --test-timeout=300000 build/test/functional/desktop-driver-e2e.test.js",
    "e2e-test:simulator": "npm run build && node --test --test-timeout=300000 build/test/functional/mobile-driver-e2e.test.js"
  },
  "dependencies": {
    "asyncbox": "^6.1.0",
    "node-simctl": "^8.0.0",
    "portscanner": "2.2.0",
    "teen_process": "^4.0.4"
  },
  "peerDependencies": {
    "appium": "^3.0.0-rc.2"
  },
  "devDependencies": {
    "@appium/docutils": "^2.5.0",
    "@appium/eslint-config-appium-ts": "^3.0.1",
    "@appium/tsconfig": "^1.0.0-rc.1",
    "@appium/types": "^1.0.0-rc.1",
    "@semantic-release/changelog": "^6.0.1",
    "@semantic-release/git": "^10.0.1",
    "@types/node": "^26.0.0",
    "@types/portscanner": "^2.1.4",
    "conventional-changelog-conventionalcommits": "^10.2.0",
    "prettier": "^3.0.3",
    "semantic-release": "^25.0.2",
    "typescript": "^6.0.2",
    "webdriverio": "^9.0.5"
  },
  "engines": {
    "node": "^20.19.0 || ^22.12.0 || >=24.0.0",
    "npm": ">=10"
  }
}
